import numpy as np
import matplotlib.pyplot as plt

# -----------------------------
# Inputs
# -----------------------------
# Aircraft components: (mass_kg, x_m)
# First 19 entries are passengers/passenger+luggage+seat
components = np.array([
    [100, -1.625],
    [100, -1.625],
    [100, -0.875],
    [100, -0.875],
    [100, -0.125],
    [100, -0.125],
    [100,  0.625],
    [100,  0.625],
    [100,  1.375],
    [100,  1.375],
    [100,  2.125],
    [100,  2.125],
    [100,  2.875],
    [100,  2.875],
    [100,  3.625],
    [100,  3.625],
    [100,  4.375],
    [100,  4.375],
    [100,  6.5  ],
    [200, -4   ],
    [100,  2   ],
    [50,   5.9 ],
    [200, -3   ],
    [1030, 0.75],
    [942,  2.4   ],
    [247, 11   ],
    [400,  1.94],
    [0,  1.5   ],
    [0,  1.5   ],
    [225,  7.11],
    [225,  7.11],
    [40,   0.1 ],
    [10,   0.25],
    [5,   -0.1 ],
    [40,   0.1 ],
    [10,   0.25],
    [5,   -0.1 ],
    [40,   0.1 ],
    [10,   0.25],
    [5,   -0.1 ],
    [40,   0.1 ],
    [10,   0.25],
    [5,   -0.1 ],
    [40,   0.1 ],
